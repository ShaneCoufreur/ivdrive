# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=ivdrive
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ivdrive

# ─── Valkey ───────────────────────────────────────────────────
VALKEY_PASSWORD=CHANGE_ME

# ─── JWT (access tokens signed with this key) ────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# ─── AES-256-GCM (encrypts VINs, Skoda creds, tokens at rest)─
ENCRYPTION_KEY=CHANGE_ME_TO_BASE64_32_BYTE_KEY

# ─── CORS (allowed frontend origins) ─────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ─── Backend logging & collector ──────────────────────────────
# LOG_LEVEL=info   (or debug to see collector API summary when COLLECTOR_DEBUG=true)
# COLLECTOR_DEBUG=true   Logs parsed API response summary (charging power/rate, driving range, connection) per vehicle poll.

# ─── Frontend (baked in at build time) ────────────────────────
# Empty = browser uses same origin (/api/*). Set only if API is on a different host.
# For https://ivdrive.eu with reverse proxy: leave empty so login calls https://ivdrive.eu/api/...
NEXT_PUBLIC_API_URL=
